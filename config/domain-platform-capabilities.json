        "format": "classical",
        "rule_mappings": {
          "IP-CIDR": "IP-CIDR",
          "IP-CIDR6": "IP-CIDR6"
        },
        "unsupported_kinds": [],
        "empty_policy": "omit",
        "compiler": "none",
        "verifier": "classical-ip"
      }
    },
    "quanx": {
      "public_name": "Quantumult X",
